# Server-side only — read by `server/` at runtime. NEVER expose in the client
# (no VITE_ prefix). Copy this file to `.env` and fill in your values.
ZAI_API_KEY=your-api-key-here
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
ZAI_MODEL=glm-5.2

# Optional: override where the client sends /api/* requests.
# Leave empty for same-origin (default). Set only if the client and the API
# server are served from different origins in dev.
# VITE_API_BASE=
